-- ============================================================================
-- Curator Policy Proposals — generated by Managed Agent board-note workflow
-- ============================================================================

CREATE TABLE IF NOT EXISTS curator_policy_proposals (
    ts              TIMESTAMPTZ NOT NULL,
    proposal_id     TEXT NOT NULL,
    session_id      TEXT,
    tenant_id       TEXT,
    circular_id     TEXT,
    title           TEXT,
    summary         TEXT,
    affected_policies TEXT,      -- JSON array of policy identifiers
    regulatory_refs   TEXT,      -- JSON array of {doc_id, section}
    risk_rating       TEXT,      -- Low / Medium / High / Critical
    committee_recommendation TEXT,
    status            TEXT,      -- draft / pending_review / approved / rejected
    created_by_agent_session TEXT,
    content_json      TEXT,      -- Full board note as JSON
    PRIMARY KEY (ts, proposal_id)
);

SELECT create_hypertable('curator_policy_proposals', 'ts', if_not_exists => TRUE);

CREATE INDEX IF NOT EXISTS idx_curator_policy_proposals_tenant
    ON curator_policy_proposals (tenant_id, ts DESC);
CREATE INDEX IF NOT EXISTS idx_curator_policy_proposals_session
    ON curator_policy_proposals (session_id);
CREATE INDEX IF NOT EXISTS idx_curator_policy_proposals_status
    ON curator_policy_proposals (status, ts DESC);
